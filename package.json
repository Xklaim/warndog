{
  "name": "warndog",
  "version": "1.0.0",
  "description": "A brutally honest senior engineer watching your JavaScript/Node.js code in real time",
  "keywords": [
    "static-analysis",
    "code-quality",
    "javascript",
    "nodejs",
    "ast",
    "debugging",
    "async",
    "bugs"
  ],
  "homepage": "https://github.com/warndog/warndog#readme",
  "bugs": {
    "url": "https://github.com/warndog/warndog/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/warndog/warndog.git"
  },
  "license": "MIT",
  "author": "Warndog Contributors",
  "main": "src/index.js",
  "bin": {
    "warndog": "./bin/warndog.js"
  },
  "scripts": {
    "start": "node bin/warndog.js",
    "test": "jest --testPathPattern=tests/",
    "test:unit": "jest --testPathPattern=tests/unit/",
    "test:integration": "jest --testPathPattern=tests/integration/",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js",
    "dev": "node bin/warndog.js"
  },
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "cosmiconfig": "^8.3.6",
    "glob": "^10.3.10",
    "ora": "^5.4.1",
    "boxen": "^5.1.2",
    "figures": "^3.2.0",
    "table": "^6.8.1",
    "semver": "^7.5.4",
    "micromatch": "^4.0.5",
    "source-map": "^0.7.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
